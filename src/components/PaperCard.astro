---
interface Props {
  title: string;
  authors: string[];
  venue: string;
  arxiv: string;
  hook: string;
  role: string;
  links?: Record<string, string>;
  selfName?: string;
}

const {
  title,
  authors,
  venue,
  arxiv,
  hook,
  role,
  links = {},
  selfName = "Zhuchenyang Liu",
} = Astro.props;
---

<article class="paper-card">
  <p class="hook">{hook}</p>
  <h3 class="paper-title">
    <a href={`https://arxiv.org/abs/${arxiv}`} target="_blank">{title}</a>
  </h3>
  <p class="authors">
    {authors.map((author, i) => (
      <>
        {i > 0 && ", "}
        {author === selfName ? <strong>{author}</strong> : <span>{author}</span>}
      </>
    ))}
  </p>
  <div class="paper-meta">
    <span class="venue">{venue}</span>
    <div class="paper-links">
      <a href={`https://arxiv.org/abs/${arxiv}`} target="_blank" class="link-pill">arXiv</a>
      <a href={`https://arxiv.org/pdf/${arxiv}`} target="_blank" class="link-pill">PDF</a>
      {Object.entries(links).map(([label, url]) => (
        <a href={url} target="_blank" class="link-pill">{label}</a>
      ))}
    </div>
  </div>
</article>

<style>
  .paper-card {
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .paper-card:hover {
    border-color: #d6d3d1;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .hook {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 0.5rem;
    line-height: 1.5;
    font-style: italic;
  }

  .paper-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.35rem;
  }

  .paper-title a {
    color: var(--text);
  }

  .paper-title a:hover {
    color: var(--accent);
  }

  .authors {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .paper-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .venue {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    font-style: italic;
  }

  .paper-links {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .link-pill {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    background: var(--tag-bg);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    transition: all 0.15s;
    text-transform: capitalize;
  }

  .link-pill:hover {
    background: var(--tag-first);
    color: var(--tag-first-text);
    border-color: var(--tag-first);
  }
</style>
